#!/usr/bin/env bash
# 薄启动器：优先 Python，否则 Node
set -euo pipefail
DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

if command -v python3 >/dev/null 2>&1; then
  exec python3 "$DIR/run.py" "$@"
elif command -v python >/dev/null 2>&1; then
  exec python "$DIR/run.py" "$@"
elif command -v node >/dev/null 2>&1; then
  exec node "$DIR/run.mjs" "$@"
else
  echo "错误: 需要 Python 3 或 Node.js" >&2
  echo "  macOS: brew install python  或  brew install node" >&2
  echo "  Windows: winget install Python.Python.3.12" >&2
  exit 127
fi
