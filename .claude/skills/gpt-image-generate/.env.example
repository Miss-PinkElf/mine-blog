# 与 run.py / run.mjs 同级；复制为 .env 后填写
# cp .env.example .env
# Windows: copy .env.example .env

OPENAI_API_KEY=你的key填这里
OPENAI_BASE_URL=https://shell.wyzlab.ai/v1
OPENAI_MODEL=gpt-image-2

# 单次请求超时（秒）。生图接口慢时可调大，但过大会导致干等很久
# CURL_CONNECT_TIMEOUT=20
# CURL_MAX_TIME=180
# REQUEST_MAX_TIME=180

# 输入参考图预处理（仅影响上传，不影响输出 png）
# GPT_IMAGE_PREP=medium
# GPT_IMAGE_JPEG_QUALITY=90
# GPT_IMAGE_TARGET_BYTES=700000
# GPT_IMAGE_MAX_EDGE=0
# GPT_IMAGE_MAX_IMAGES=4
# GPT_IMAGE_RETRIES=5
