---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolCard from '../../components/site/ToolCard.astro';
import { tools } from '../../data/tools';

const base = import.meta.env.BASE_URL;
---

<BaseLayout title="工具" description="無限凜浏览器内小工具集合">
  <section class="tools-index">
    <header class="tools-index__header">
      <h1 class="tools-index__title">工具</h1>
      <p class="tools-index__lead muted">浏览器内处理，数据不上传服务器</p>
    </header>

    <ul class="tools-index__list">
      {
        tools.map((tool) => (
          <li>
            <ToolCard
              title={tool.title}
              description={tool.description}
              href={`${base}tools/${tool.slug}/`}
            />
          </li>
        ))
      }
    </ul>
  </section>
</BaseLayout>

<style>
  .tools-index__header {
    margin-bottom: 1.75rem;
  }

  .tools-index__title {
    margin: 0 0 0.4rem;
    font-size: 1.75rem;
  }

  .tools-index__lead {
    margin: 0;
    font-size: 0.95rem;
  }

  .tools-index__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
</style>
