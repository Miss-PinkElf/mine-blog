---
import ShellLayout from '../../layouts/ShellLayout.astro';

const base = import.meta.env.BASE_URL;

/**
 * 無限凜 OC 画廊条目。
 * src 相对 public/；href 经 BASE_URL，适配 GitHub Pages 子路径。
 */
const items = [
  {
    id: 'rin-04',
    src: 'gallery/rin-04-jk-server-room.png',
    label: 'JK · Server Room',
    caption: '机房主视觉 · 制服立绘',
    featured: true,
  },
  {
    id: 'rin-01',
    src: 'gallery/rin-01-global-design.png',
    label: 'Global Design',
    caption: '全身三视图 · 配件与配色',
    featured: false,
  },
  {
    id: 'rin-02',
    src: 'gallery/rin-02-angles-expressions.png',
    label: 'Angles & Expressions',
    caption: '头像角度 · 表情差分',
    featured: false,
  },
  {
    id: 'rin-03',
    src: 'gallery/rin-03-actions.png',
    label: 'Actions',
    caption: '站姿 / 编程 / 戴耳机 / 出行',
    featured: false,
  },
] as const;
---

<ShellLayout title="Gallery" description="無限凜 · OC 设定与插画">
  <h1 class="shell-page-title"><span>Gallery</span></h1>
  <p class="shell-lead">無限凜角色设定与场景插画。悬停可轻微放大；灯箱后续再加。</p>

  <div class="shell-gallery" role="list">
    {
      items.map((item) => (
        <figure
          class:list={['shell-gallery__item', item.featured && 'shell-gallery__item--featured']}
          role="listitem"
        >
          <img
            class="shell-gallery__img"
            src={`${base}${item.src}`}
            alt={`${item.label} — ${item.caption}`}
            loading={item.featured ? 'eager' : 'lazy'}
            decoding="async"
          />
          <figcaption class="shell-gallery__caption">
            <span class="shell-gallery__caption-label">{item.label}</span>
            <span class="shell-gallery__caption-sub">{item.caption}</span>
          </figcaption>
        </figure>
      ))
    }
  </div>
</ShellLayout>
