---
import { getCollection } from 'astro:content';
import ShellLayout from '../layouts/ShellLayout.astro';
import PostCard from '../components/site/PostCard.astro';
import { tools } from '../data/tools';

const base = import.meta.env.BASE_URL;
const posts = (await getCollection('posts', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 2);

const primaryTool = tools[0];
---

<ShellLayout title="無限凜" description="無限凜 — 开发者博客与小工具">
  <div class="shell-hero__glow" aria-hidden="true"></div>

  <section class="shell-hero">
    <p class="shell-hero__eyebrow">Mugen Rin · Official Shell</p>
    <h1 class="shell-hero__title">無限凜</h1>
    <p class="shell-hero__lead">
      暗色基底 + 赛博绿强调。写博客，也放浏览器小工具。右上角打开全站菜单。
    </p>
  </section>

  <section class="shell-card-grid" aria-label="主要入口">
    <a class="shell-card" href={`${base}blog/`}>
      <h2 class="shell-card__title">Blog</h2>
      <p class="shell-card__desc">笔记与长文（极简阅读区）</p>
    </a>
    <a class="shell-card" href={`${base}tools/`}>
      <h2 class="shell-card__title">Tools</h2>
      <p class="shell-card__desc">{primaryTool ? primaryTool.title : '浏览器内小工具'}</p>
    </a>
    <a class="shell-card" href={`${base}profile/`}>
      <h2 class="shell-card__title">Profile</h2>
      <p class="shell-card__desc">档案式 STATUS / LIKES</p>
    </a>
    <a class="shell-card" href={`${base}gallery/`}>
      <h2 class="shell-card__title">Gallery</h2>
      <p class="shell-card__desc">占位画廊网格</p>
    </a>
    <a class="shell-card" href={`${base}contact/`}>
      <h2 class="shell-card__title">Contact</h2>
      <p class="shell-card__desc">联系表单皮</p>
    </a>
    <a class="shell-card" href={`${base}classic/`}>
      <h2 class="shell-card__title">Classic</h2>
      <p class="shell-card__desc">原极简入口（暂时保留）</p>
    </a>
  </section>

  {
    posts.length > 0 && (
      <section class="shell-section" aria-label="最近文章" style="margin-top: 2.5rem">
        <h2 class="shell-section__heading">Recent Posts</h2>
        <ul style="list-style:none;margin:0;padding:0;display:flex;flex-direction:column;gap:1rem">
          {posts.map((post) => (
            <li>
              <PostCard
                title={post.data.title}
                description={post.data.description}
                pubDate={post.data.pubDate}
                href={`${base}blog/${post.id}/`}
              />
            </li>
          ))}
        </ul>
      </section>
    )
  }
</ShellLayout>
